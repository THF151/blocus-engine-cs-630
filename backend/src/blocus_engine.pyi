from __future__ import annotations

from collections.abc import Sequence
from typing import ClassVar

def engine_health() -> bool: ...

class BlocusError(Exception): ...
class InputError(BlocusError): ...
class RuleViolationError(BlocusError): ...
class EngineError(BlocusError): ...

class PlayerColor:
    BLUE: ClassVar[PlayerColor]
    YELLOW: ClassVar[PlayerColor]
    RED: ClassVar[PlayerColor]
    GREEN: ClassVar[PlayerColor]
    BLACK: ClassVar[PlayerColor]
    WHITE: ClassVar[PlayerColor]

    def __init__(self, value: str) -> None: ...
    @staticmethod
    def blue() -> PlayerColor: ...
    @staticmethod
    def yellow() -> PlayerColor: ...
    @staticmethod
    def red() -> PlayerColor: ...
    @staticmethod
    def green() -> PlayerColor: ...
    @staticmethod
    def black() -> PlayerColor: ...
    @staticmethod
    def white() -> PlayerColor: ...
    @property
    def name(self) -> str: ...
    @property
    def value(self) -> str: ...
    @property
    def index(self) -> int: ...

class GameStatus:
    IN_PROGRESS: ClassVar[GameStatus]
    FINISHED: ClassVar[GameStatus]

    def __init__(self, value: str) -> None: ...
    @staticmethod
    def in_progress() -> GameStatus: ...
    @staticmethod
    def finished() -> GameStatus: ...
    @property
    def name(self) -> str: ...
    @property
    def value(self) -> str: ...

class ScoringMode:
