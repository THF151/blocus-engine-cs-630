    def game_id(self) -> str: ...
    @property
    def player_id(self) -> str: ...
    @property
    def color(self) -> PlayerColor: ...
    @property
    def piece_id(self) -> int: ...
    @property
    def orientation_id(self) -> int: ...
    @property
    def row(self) -> int: ...
    @property
    def col(self) -> int: ...
    @property
