class ScoreEntry:
    @property
    def player_id(self) -> str: ...
    @property
    def score(self) -> int: ...

class ScoreBoard:
    @property
    def scoring(self) -> ScoringMode: ...
    @property
    def entries(self) -> list[ScoreEntry]: ...

class BlocusEngine:
    def __init__(self) -> None: ...
    def initialize_game(self, config: GameConfig) -> GameState: ...
    def apply(
        self,
        state: GameState,
        command: PlaceCommand | PassCommand,
    ) -> GameResult: ...
    def pieces(self) -> list[Piece]: ...
    def piece(self, piece_id: int) -> Piece: ...
    def get_valid_moves(
        self,
        state: GameState,
        player_id: str,
        color: PlayerColor,
    ) -> list[LegalMove]: ...
    def get_valid_moves_for_piece(
        self,
        state: GameState,
        player_id: str,
        color: PlayerColor,
        piece_id: int,
    ) -> list[LegalMove]: ...
    def has_any_valid_move(
        self,
        state: GameState,
        player_id: str,
        color: PlayerColor,
    ) -> bool: ...
    def has_any_valid_move_for_piece(
        self,
        state: GameState,
        player_id: str,
        color: PlayerColor,
        piece_id: int,
    ) -> bool: ...
    def score_game(
        self,
        state: GameState,
        scoring: ScoringMode,
    ) -> ScoreBoard: ...
