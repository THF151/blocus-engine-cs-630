    def basic() -> ScoringMode: ...
    @staticmethod
    def advanced() -> ScoringMode: ...
    @property
    def name(self) -> str: ...
    @property
    def value(self) -> str: ...

class GameMode:
    TWO_PLAYER: ClassVar[GameMode]
    THREE_PLAYER: ClassVar[GameMode]
    FOUR_PLAYER: ClassVar[GameMode]
    DUO: ClassVar[GameMode]

    def __init__(self, value: str) -> None: ...
    @staticmethod
    def two_player() -> GameMode: ...
    @staticmethod
    def three_player() -> GameMode: ...
    @staticmethod
    def four_player() -> GameMode: ...
    @staticmethod
    def duo() -> GameMode: ...
    @property
    def name(self) -> str: ...
    @property
    def value(self) -> str: ...

class DomainEventKind:
    MOVE_APPLIED: ClassVar[DomainEventKind]
    PLAYER_PASSED: ClassVar[DomainEventKind]
    TURN_ADVANCED: ClassVar[DomainEventKind]
    GAME_FINISHED: ClassVar[DomainEventKind]

    def __init__(self, value: str) -> None: ...
    @staticmethod
