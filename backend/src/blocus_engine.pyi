class LegalMove:
    @property
    def piece_id(self) -> int: ...
    @property
    def orientation_id(self) -> int: ...
    @property
    def row(self) -> int: ...
    @property
    def col(self) -> int: ...
    @property
    def board_index(self) -> int: ...
    @property
