    @staticmethod
    def turn_advanced() -> DomainEventKind: ...
    @staticmethod
    def game_finished() -> DomainEventKind: ...
    @property
    def name(self) -> str: ...
    @property
    def value(self) -> str: ...

class DomainResponseKind:
    MOVE_APPLIED: ClassVar[DomainResponseKind]
    PLAYER_PASSED: ClassVar[DomainResponseKind]
    GAME_FINISHED: ClassVar[DomainResponseKind]

    def __init__(self, value: str) -> None: ...
    @staticmethod
    def move_applied() -> DomainResponseKind: ...
    @staticmethod
    def player_passed() -> DomainResponseKind: ...
    @staticmethod
    def game_finished() -> DomainResponseKind: ...
