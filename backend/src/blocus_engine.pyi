class GameState:
    @staticmethod
    def from_json(json_text: str) -> GameState: ...
    def to_json(self) -> str: ...
    @property
    def schema_version(self) -> int: ...
    @property
    def game_id(self) -> str: ...
    @property
    def mode(self) -> GameMode: ...
    @property
    def scoring(self) -> ScoringMode: ...
    @property
    def status(self) -> GameStatus: ...
    @property
    def version(self) -> int: ...
    @property
    def hash(self) -> int: ...
    @property
    def board_is_empty(self) -> bool: ...
    @property
    def board(self) -> BoardSnapshot: ...
    @property
    def board_size(self) -> int: ...
    @property
    def turn_order(self) -> list[PlayerColor]: ...
    @property
    def current_color(self) -> PlayerColor: ...
    @property
    def player_slots(self) -> PlayerSlots: ...
    def cell(self, row: int, col: int) -> PlayerColor | None: ...
    def occupied_cells(self, color: PlayerColor | None = None) -> list[BoardCell]: ...
    def board_matrix(self) -> list[list[PlayerColor | None]]: ...
    def board_counts(self) -> list[tuple[PlayerColor, int]]: ...
    def cells_for_color(self, color: PlayerColor) -> list[BoardCell]: ...
    def used_piece_ids(self, color: PlayerColor) -> list[int]: ...
    def available_piece_ids(self, color: PlayerColor) -> list[int]: ...
    def used_pieces(self, color: PlayerColor) -> list[Piece]: ...
    def available_pieces(self, color: PlayerColor) -> list[Piece]: ...
    def inventory_summary(self, color: PlayerColor) -> InventorySummary: ...
    def remaining_square_count(self, color: PlayerColor) -> int: ...

